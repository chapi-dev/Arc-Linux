{
  "properties": {
    "displayName": "[Arc-Linux] Audit Linux Arc machines without AutomaticByPlatform patching",
    "description": "AuditIfNotExists: marca como NonCompliant las maquinas Arc Linux que no tienen patchSettings.patchMode=AutomaticByPlatform y patchSettings.assessmentMode=AutomaticByPlatform. El modo se debe aplicar via API directa (no Modify policy, ya que el alias no es modifiable en Arc). Ver scripts/onboarding/07-set-patchmode-on-arc-machines.ps1.",
    "policyType": "Custom",
    "mode": "Indexed",
    "metadata": {
      "category": "Azure Update Manager",
      "version": "2.0.0"
    },
    "parameters": {
      "effect": {
        "type": "String",
        "allowedValues": [ "AuditIfNotExists", "Disabled" ],
        "defaultValue": "AuditIfNotExists"
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          { "field": "type", "equals": "Microsoft.HybridCompute/machines" },
          { "field": "Microsoft.HybridCompute/machines/osName", "equals": "linux" },
          { "field": "tags['aum']", "equals": "enabled" }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]",
        "details": {
          "type": "Microsoft.HybridCompute/machines",
          "existenceCondition": {
            "allOf": [
              {
                "field": "Microsoft.HybridCompute/machines/osProfile.linuxConfiguration.patchSettings.patchMode",
                "equals": "AutomaticByPlatform"
              },
              {
                "field": "Microsoft.HybridCompute/machines/osProfile.linuxConfiguration.patchSettings.assessmentMode",
                "equals": "AutomaticByPlatform"
              }
            ]
          }
        }
      }
    }
  }
}
