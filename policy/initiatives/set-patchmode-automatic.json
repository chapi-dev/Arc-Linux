{
  "properties": {
    "displayName": "[Arc-Linux] Enable AutomaticByPlatform patching on Linux Arc machines",
    "description": "Modify: fuerza patchMode=AutomaticByPlatform y assessmentMode=AutomaticByPlatform en maquinas Arc Linux para que sean gestionables por Azure Update Manager.",
    "policyType": "Custom",
    "mode": "Indexed",
    "metadata": {
      "category": "Azure Update Manager",
      "version": "1.0.0"
    },
    "parameters": {
      "effect": {
        "type": "String",
        "allowedValues": [ "Modify", "Audit", "Disabled" ],
        "defaultValue": "Modify"
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          { "field": "type", "equals": "Microsoft.HybridCompute/machines" },
          { "field": "Microsoft.HybridCompute/machines/osName", "equals": "linux" },
          { "field": "tags['aum']", "equals": "enabled" }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]",
        "details": {
          "roleDefinitionIds": [
            "/providers/Microsoft.Authorization/roleDefinitions/cd570a14-e51a-42ad-bac8-bafd67325302"
          ],
          "operations": [
            {
              "operation": "addOrReplace",
              "field": "Microsoft.HybridCompute/machines/osProfile.linuxConfiguration.patchSettings.assessmentMode",
              "value": "AutomaticByPlatform"
            },
            {
              "operation": "addOrReplace",
              "field": "Microsoft.HybridCompute/machines/osProfile.linuxConfiguration.patchSettings.patchMode",
              "value": "AutomaticByPlatform"
            }
          ]
        }
      }
    }
  }
}
